# Copy to `.env` in this folder (optional). `.env` is gitignored.
#
# When set to 1 or true, every cold start opens onboarding (ignores saved completion).
# Useful for Expo Go / dev. Omit or set to 0 for normal behavior.
#
#   EXPO_PUBLIC_FORCE_ONBOARDING=1 npx expo start
#
EXPO_PUBLIC_FORCE_ONBOARDING=
